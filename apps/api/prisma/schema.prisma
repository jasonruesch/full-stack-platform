// BookmarkVault data model. A user owns collections; each collection holds
// bookmarks; bookmarks are tagged via a many-to-many join; a collection can be
// exposed read-only through a Share token.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collections Collection[]
  bookmarks   Bookmark[]
  tags        Tag[]
}

model Collection {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  description String?
  color       String   @default("#6366f1")
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookmarks Bookmark[]
  shares    Share[]

  @@index([ownerId])
}

model Bookmark {
  id           String   @id @default(cuid())
  collectionId String
  ownerId      String
  url          String
  title        String
  description  String?
  faviconUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  owner      User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tags       BookmarkTag[]

  @@index([collectionId])
  @@index([ownerId])
}

model Tag {
  id      String @id @default(cuid())
  ownerId String
  name    String
  color   String @default("#64748b")

  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookmarks BookmarkTag[]

  @@unique([ownerId, name])
  @@index([ownerId])
}

model BookmarkTag {
  bookmarkId String
  tagId      String

  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookmarkId, tagId])
  @@index([tagId])
}

model Share {
  token        String    @id
  collectionId String
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}
